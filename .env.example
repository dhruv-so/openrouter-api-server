# OpenRouter Configuration
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional OpenRouter overrides
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://your-site.example
OPENROUTER_APP_TITLE=Gemini-3 API Server
OPENROUTER_TIMEOUT=60

# Server Security Configuration
# IMPORTANT: Set a strong, random API key for authenticating requests to your server
SERVER_API_KEY=your-strong-random-server-api-key-here

# CORS Configuration
# Comma-separated list of allowed origins (e.g., https://yourdomain.com,https://app.yourdomain.com)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
# Format: "requests/period" (e.g., "10/minute", "100/hour", "1000/day")
RATE_LIMIT=10/minute

# Request Timeout (seconds) for fetching prompt/image URLs
REQUEST_TIMEOUT=15

# Generation Defaults (optional)
DEFAULT_TEMPERATURE=1.0
DEFAULT_TOP_P=0.95
DEFAULT_MAX_OUTPUT_TOKENS=12000
